<% content_for :title, "🍳 Fila de Produção - Cozinha" %>

<!-- Fila da Cozinha -->
<div class="grid grid-cols-1 lg:grid-cols-4 gap-8 h-[calc(100vh-12rem)]">
  <!-- Pedidos em Preparação (Fila Ativa) -->
  <div class="lg:col-span-3 bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg flex flex-col h-full">
    <div class="flex items-center justify-between mb-6 shrink-0">
      <h3 class="text-lg font-bold text-white flex items-center">
        👩‍🍳 Em Preparação
        <span class="ml-3 bg-orange-500/10 text-orange-400 px-3 py-1 rounded-full text-xs font-semibold"><%= @in_preparation_orders.count %> pendentes</span>
      </h3>
      <span class="text-xs text-zinc-500 flex items-center">
        <span class="w-2 h-2 rounded-full bg-emerald-500 mr-2 animate-ping"></span>
        Atualização automática ativa
      </span>
    </div>

    <div class="flex-1 overflow-y-auto space-y-4 pr-2">
      <% if @in_preparation_orders.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @in_preparation_orders.each do |order| %>
            <div class="bg-zinc-950 border border-zinc-800 hover:border-zinc-700 transition-colors rounded-2xl p-5 flex flex-col justify-between shadow-md">
              <div>
                <!-- Card Header -->
                <div class="flex items-start justify-between border-b border-zinc-800 pb-3 mb-3">
                  <div>
                    <span class="text-base font-bold text-white"><%= order.number %></span>
                    <div class="text-xs text-zinc-400 font-semibold mt-0.5">
                      <%= order.order_type.titleize %> <%= " # #{order.dining_table.number}" if order.mesa? %>
                    </div>
                  </div>
                  <!-- Tempo decorrido -->
                  <span class="text-xs font-bold px-2.5 py-1 rounded-xl bg-orange-500/10 text-orange-400 border border-orange-500/20">
                    ⏱️ <%= time_ago_in_words(order.updated_at) %>
                  </span>
                </div>

                <!-- Itens do Pedido (Focado em Pizzas e Sabores) -->
                <div class="space-y-3 my-4">
                  <% order.order_items.each do |item| %>
                    <div class="text-sm">
                      <div class="flex items-start">
                        <span class="font-extrabold text-orange-500 mr-2"><%= item.quantity.to_i %>x</span>
                        <div class="flex-1">
                          <span class="font-bold text-zinc-200">
                            <%= item.product.is_pizza? ? "Pizza #{item.product_size&.size_name}" : item.product.name %>
                          </span>
                          
                          <!-- Sabores se for Pizza -->
                          <% if item.product.is_pizza? %>
                            <div class="text-xs text-zinc-300 font-medium mt-1 pl-4 border-l-2 border-orange-500/30">
                              🍕 Sabores: <%= item.flavors.pluck(:name).join(" / ") %>
                            </div>
                          <% end %>

                          <!-- Adicionais se houver -->
                          <% if item.additionals.any? %>
                            <div class="text-xs text-zinc-500 mt-1 pl-4">
                              ➕ Adicionais: <%= item.additionals.pluck(:name).join(", ") %>
                            </div>
                          <% end %>

                          <!-- Observações se houver -->
                          <% if item.observation.present? %>
                            <div class="text-xs bg-zinc-900 border border-zinc-800 text-amber-400 font-medium px-2 py-1 rounded-lg mt-1.5">
                              ⚠️ Obs: <%= item.observation %>
                            </div>
                          <% end %>
                        </div>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>

              <!-- Action button -->
              <%= button_to mark_ready_order_path(order), method: :patch, class: "w-full mt-4 rounded-xl py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-bold text-sm tracking-wide transition-colors flex items-center justify-center cursor-pointer shadow-md shadow-emerald-500/10" do %>
                ✅ Marcar como Pronto
              <% end %>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center h-full text-zinc-500 py-12">
          <span class="text-5xl mb-4">💤</span>
          <p class="text-sm font-semibold">Nenhum pedido na fila no momento.</p>
          <p class="text-xs text-zinc-600 mt-1">Os pedidos aparecerão aqui assim que forem enviados.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Pedidos Prontos recentemente (Última hora) -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg flex flex-col h-full">
    <div class="mb-6 shrink-0">
      <h3 class="text-lg font-bold text-white flex items-center">
        ✅ Concluídos
        <span class="ml-2.5 text-xs text-zinc-500 font-medium">(Última hora)</span>
      </h3>
    </div>

    <div class="flex-1 overflow-y-auto space-y-3 pr-2">
      <% if @ready_orders.any? %>
        <% @ready_orders.each do |order| %>
          <div class="p-4 rounded-2xl bg-zinc-950 border border-zinc-800 flex flex-col justify-between opacity-80 hover:opacity-100 transition-opacity">
            <div class="flex items-center justify-between border-b border-zinc-900 pb-2 mb-2">
              <div>
                <span class="text-sm font-bold text-zinc-300"><%= order.number %></span>
                <div class="text-xs text-zinc-500 font-semibold"><%= order.order_type.titleize %><%= " Mesa #{order.dining_table.number}" if order.mesa? %></div>
              </div>
              <span class="text-[10px] font-bold px-2 py-0.5 rounded-full bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                Pronto
              </span>
            </div>
            <div class="text-xs text-zinc-500 space-y-1">
              <% order.order_items.each do |item| %>
                <div><%= item.quantity.to_i %>x <%= item.description %></div>
              <% end %>
            </div>
            <div class="text-[10px] text-zinc-600 mt-2 text-right">
              Pronto há <%= time_ago_in_words(order.updated_at) %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm text-zinc-600 text-center py-8">Nenhum pedido concluído recentemente.</p>
      <% end %>
    </div>
  </div>
</div>
