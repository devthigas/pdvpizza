<div class="w-full max-w-md bg-zinc-900/50 border border-zinc-800 rounded-3xl p-8 shadow-2xl backdrop-blur-md">
  <!-- Brand Header -->
  <div class="text-center mb-8">
    <div class="w-16 h-16 rounded-2xl bg-orange-600/10 border border-orange-500/20 flex items-center justify-center text-4xl mx-auto mb-4 animate-bounce">
      🍕
    </div>
    <h2 class="text-2xl font-extrabold text-white tracking-tight">Pizza<span class="text-orange-500">PDV</span></h2>
    <p class="text-sm text-zinc-400 mt-2">Faça login para operar o ponto de venda</p>
  </div>

  <% if alert = flash[:alert] %>
    <div class="bg-red-500/10 border border-red-500/20 text-red-400 p-4 rounded-2xl text-sm font-medium mb-6">
      ⚠️ <%= alert %>
    </div>
  <% end %>

  <% if notice = flash[:notice] %>
    <div class="bg-emerald-500/10 border border-emerald-500/20 text-emerald-400 p-4 rounded-2xl text-sm font-medium mb-6">
      ✅ <%= notice %>
    </div>
  <% end %>

  <%= form_with url: session_url, class: "space-y-6" do |form| %>
    <div>
      <%= form.label :email_address, "E-mail do Operador", class: "block text-xs font-semibold text-zinc-400 uppercase tracking-wider mb-2" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "ex: admin@pizzaria.com", value: params[:email_address], class: "block w-full rounded-2xl bg-zinc-950 border border-zinc-800 focus:border-orange-500 focus:ring-1 focus:ring-orange-500 text-zinc-100 placeholder-zinc-600 px-4 py-3.5 transition-colors focus:outline-none" %>
    </div>

    <div>
      <div class="flex items-center justify-between mb-2">
        <%= form.label :password, "Senha", class: "block text-xs font-semibold text-zinc-400 uppercase tracking-wider" %>
        <%= link_to "Esqueceu a senha?", new_password_path, class: "text-xs text-orange-500 hover:underline" %>
      </div>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "••••••••", maxlength: 72, class: "block w-full rounded-2xl bg-zinc-950 border border-zinc-800 focus:border-orange-500 focus:ring-1 focus:ring-orange-500 text-zinc-100 placeholder-zinc-600 px-4 py-3.5 transition-colors focus:outline-none" %>
    </div>

    <%= form.submit "Entrar no Sistema", class: "w-full rounded-2xl py-4 bg-orange-500 hover:bg-orange-600 text-white font-bold tracking-wide transition-all shadow-lg shadow-orange-500/20 active:scale-[0.98] cursor-pointer" %>
  <% end %>
</div>
