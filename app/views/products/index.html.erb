<% content_for :title, "📦 Cardápio - Produtos" %>

<div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg">
  <div class="flex items-center justify-between mb-8">
    <h3 class="text-lg font-bold text-white">Todos os Produtos</h3>
    <% if Current.session.user.admin? || Current.session.user.gerente? %>
      <%= link_to "Novo Produto", new_product_path, class: "px-5 py-3 rounded-2xl bg-orange-500 hover:bg-orange-600 text-white font-bold text-sm tracking-wide transition-all shadow-lg shadow-orange-500/20 active:scale-[0.98]" %>
    <% end %>
  </div>

  <% if @products.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse text-sm text-zinc-300">
        <thead>
          <tr class="border-b border-zinc-800 text-zinc-500 font-semibold">
            <th class="py-4 px-3">Nome</th>
            <th class="py-4 px-3">Categoria</th>
            <th class="py-4 px-3">Tipo</th>
            <th class="py-4 px-3">Estoque Atual</th>
            <th class="py-4 px-3 text-right">Preço Venda</th>
            <th class="py-4 px-3 text-center">Status</th>
            <th class="py-4 px-3 text-center">Ações</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800">
          <% @products.each do |prod| %>
            <tr class="hover:bg-zinc-950/40 transition-colors">
              <td class="py-4 px-3">
                <span class="font-bold text-white"><%= prod.name %></span>
                <div class="text-xs text-zinc-500 mt-0.5"><%= prod.description %></div>
              </td>
              <td class="py-4 px-3">
                <%= prod.category.name %>
              </td>
              <td class="py-4 px-3">
                <span class="px-2 py-0.5 rounded-lg text-xs font-semibold <%= prod.is_pizza? ? 'bg-orange-500/10 text-orange-400' : 'bg-blue-500/10 text-blue-400' %>">
                  <%= prod.is_pizza? ? '🍕 Pizza' : '🥤 Comum' %>
                </span>
              </td>
              <td class="py-4 px-3">
                <% if prod.is_pizza? %>
                  <span class="text-zinc-500">-</span>
                <% else %>
                  <span class="<%= prod.current_stock <= prod.min_stock ? 'text-red-400 font-bold' : 'text-zinc-300' %>">
                    <%= prod.current_stock.to_i %> <%= prod.unit %>
                  </span>
                <% end %>
              </td>
              <td class="py-4 px-3 text-right font-bold text-white">
                <%= prod.display_price %>
              </td>
              <td class="py-4 px-3 text-center">
                <span class="px-2 py-0.5 rounded-lg text-xs font-bold <%= prod.active? ? 'bg-emerald-500/10 text-emerald-400' : 'bg-zinc-800 text-zinc-500' %>">
                  <%= prod.active? ? 'Ativo' : 'Inativo' %>
                </span>
              </td>
              <td class="py-4 px-3 text-center">
                <div class="flex items-center justify-center space-x-2">
                  <% if !prod.is_pizza? %>
                    <%= link_to "📦 Estoque", product_stock_movements_path(prod), class: "px-3 py-1.5 rounded-xl bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold text-xs" %>
                  <% end %>
                  <% if Current.session.user.admin? || Current.session.user.gerente? %>
                    <%= link_to "Editar", edit_product_path(prod), class: "px-3 py-1.5 rounded-xl bg-zinc-800 hover:bg-zinc-750 text-zinc-300 font-bold text-xs" %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-zinc-500 text-center py-12">Nenhum produto cadastrado.</p>
  <% end %>
</div>
