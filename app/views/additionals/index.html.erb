<% content_for :title, "➕ Cardápio - Adicionais" %>

<div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg">
  <div class="flex items-center justify-between mb-8">
    <h3 class="text-lg font-bold text-white">Adicionais Cadastrados</h3>
    <% if Current.session.user.admin? || Current.session.user.gerente? %>
      <%= link_to "Novo Adicional", new_additional_path, class: "px-5 py-3 rounded-2xl bg-orange-500 hover:bg-orange-600 text-white font-bold text-sm tracking-wide transition-all shadow-lg shadow-orange-500/20 active:scale-[0.98]" %>
    <% end %>
  </div>

  <% if @additionals.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse text-sm text-zinc-300">
        <thead>
          <tr class="border-b border-zinc-800 text-zinc-500 font-semibold">
            <th class="py-4 px-3">Nome</th>
            <th class="py-4 px-3">Descrição</th>
            <th class="py-4 px-3 text-right">Preço Adicional</th>
            <th class="py-4 px-3 text-center">Status</th>
            <% if Current.session.user.admin? || Current.session.user.gerente? %>
              <th class="py-4 px-3 text-center">Ações</th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-800">
          <% @additionals.each do |add| %>
            <tr class="hover:bg-zinc-950/40 transition-colors">
              <td class="py-4 px-3 font-bold text-white">
                <%= add.name %>
              </td>
              <td class="py-4 px-3 text-xs text-zinc-400">
                <%= add.description %>
              </td>
              <td class="py-4 px-3 text-right font-bold text-orange-400">
                R$ <%= '%.2f' % add.price %>
              </td>
              <td class="py-4 px-3 text-center">
                <span class="px-2 py-0.5 rounded-lg text-xs font-bold <%= add.active? ? 'bg-emerald-500/10 text-emerald-400' : 'bg-zinc-800 text-zinc-500' %>">
                  <%= add.active? ? 'Ativo' : 'Inativo' %>
                </span>
              </td>
              <% if Current.session.user.admin? || Current.session.user.gerente? %>
                <td class="py-4 px-3 text-center">
                  <%= link_to "Editar", edit_additional_path(add), class: "px-3 py-1.5 rounded-xl bg-zinc-800 hover:bg-zinc-750 text-zinc-300 font-bold text-xs" %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-zinc-500 text-center py-12">Nenhum adicional cadastrado ainda.</p>
  <% end %>
</div>
