<% content_for :title, "Dashboard" %>

<!-- Dashboard Summary Grid -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
  <!-- Card Faturamento -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 flex items-center justify-between shadow-lg">
    <div>
      <span class="text-xs font-semibold text-zinc-500 uppercase tracking-wider block mb-1">Faturamento Hoje</span>
      <span class="text-3xl font-extrabold text-white tracking-tight">R$ <%= '%.2f' % @total_sales_today %></span>
    </div>
    <div class="w-12 h-12 rounded-2xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-2xl text-emerald-400">
      💸
    </div>
  </div>

  <!-- Card Quantidade Pedidos -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 flex items-center justify-between shadow-lg">
    <div>
      <span class="text-xs font-semibold text-zinc-500 uppercase tracking-wider block mb-1">Pedidos Realizados</span>
      <span class="text-3xl font-extrabold text-white tracking-tight"><%= @orders_count_today %></span>
    </div>
    <div class="w-12 h-12 rounded-2xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-2xl text-orange-400">
      📦
    </div>
  </div>

  <!-- Card Caixa Atual -->
  <% active_register = CashRegister.find_by(user: Current.session.user, status: :open) %>
  <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 flex items-center justify-between shadow-lg">
    <div>
      <span class="text-xs font-semibold text-zinc-500 uppercase tracking-wider block mb-1">Status do Caixa</span>
      <span class="text-xl font-bold tracking-tight <%= active_register ? 'text-emerald-400' : 'text-amber-400' %>">
        <%= active_register ? 'Operando (Aberto)' : 'Fechado' %>
      </span>
    </div>
    <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-2xl <%= active_register ? 'bg-emerald-500/10 border border-emerald-500/20 text-emerald-400' : 'bg-amber-500/10 border border-amber-500/20 text-amber-400' %>">
      🏪
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  <!-- Pedidos Ativos (Em Andamento) -->
  <div class="lg:col-span-2 space-y-6">
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-lg font-bold text-white">Pedidos em Andamento</h3>
        <span class="bg-zinc-800 text-zinc-400 px-3 py-1 rounded-full text-xs font-semibold"><%= @pending_orders.count %> ativos</span>
      </div>

      <% if @pending_orders.any? %>
        <div class="divide-y divide-zinc-800 overflow-hidden">
          <% @pending_orders.each do |order| %>
            <div class="py-4 flex items-center justify-between first:pt-0 last:pb-0">
              <div class="flex items-center space-x-4">
                <div class="w-10 h-10 rounded-xl bg-zinc-800 flex items-center justify-center text-lg">
                  <%= order.order_type == "mesa" ? "🪑" : (order.order_type == "delivery" ? "🏍️" : "🛍️") %>
                </div>
                <div>
                  <div class="font-bold text-white flex items-center">
                    <%= order.number %>
                    <span class="ml-2 text-xs font-medium text-zinc-500">
                      (<%= order.order_type.titleize %><%= " ##{order.dining_table.number}" if order.mesa? %>)
                    </span>
                  </div>
                  <div class="text-xs text-zinc-500 mt-0.5">
                    <%= order.created_at.strftime("%H:%M") %> • <%= order.order_items.count %> itens • R$ <%= '%.2f' % order.total %>
                  </div>
                </div>
              </div>

              <!-- Status Badge -->
              <span class="px-3 py-1.5 rounded-full text-xs font-semibold
                <%= case order.status
                    when 'pending' then 'bg-amber-500/10 text-amber-400 border border-amber-500/20'
                    when 'in_kitchen' then 'bg-blue-500/10 text-blue-400 border border-blue-500/20 animate-pulse'
                    when 'ready' then 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20'
                    when 'delivering' then 'bg-purple-500/10 text-purple-400 border border-purple-500/20'
                    end %>">
                <%= case order.status
                    when 'pending' then 'Pendente'
                    when 'in_kitchen' then 'Na Cozinha'
                    when 'ready' then 'Pronto'
                    when 'delivering' then 'Entregando'
                    end %>
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-zinc-500 text-center py-6">Nenhum pedido ativo no momento.</p>
      <% end %>
    </div>
  </div>

  <!-- Sabores Mais Vendidos e Estoque Baixo -->
  <div class="space-y-6">
    <!-- Sabores Mais Vendidos -->
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg">
      <h3 class="text-lg font-bold text-white mb-6">Mais Vendidos (Sabores)</h3>
      <% if @top_flavors.any? %>
        <div class="space-y-4">
          <% @top_flavors.each_with_index do |flavor, index| %>
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-3">
                <span class="w-6 h-6 rounded-lg bg-orange-600/10 border border-orange-500/20 flex items-center justify-center text-xs font-bold text-orange-500">
                  <%= index + 1 %>
                </span>
                <span class="text-sm font-medium text-zinc-300"><%= flavor.name %></span>
              </div>
              <span class="text-xs font-bold text-zinc-500"><%= flavor.sales_count %> vendas</span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-zinc-500 text-center py-6">Nenhuma venda de pizza registrada hoje.</p>
      <% end %>
    </div>

    <!-- Alertas de Estoque Baixo -->
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg">
      <h3 class="text-lg font-bold text-white mb-6">Estoque Alerta</h3>
      <% if @low_stock_products.any? %>
        <div class="space-y-4">
          <% @low_stock_products.each do |product| %>
            <div class="flex items-center justify-between p-3 rounded-2xl bg-red-500/5 border border-red-500/10">
              <div>
                <div class="text-sm font-semibold text-zinc-200"><%= product.name %></div>
                <div class="text-xs text-zinc-500 mt-0.5">Estoque Mínimo: <%= product.min_stock.to_i %> un</div>
              </div>
              <span class="text-sm font-extrabold text-red-400 bg-red-400/10 px-2.5 py-1 rounded-xl">
                <%= product.current_stock.to_i %> un
              </span>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="p-4 bg-emerald-500/5 border border-emerald-500/10 rounded-2xl flex items-center">
          <span class="text-lg mr-2">✅</span>
          <p class="text-xs text-emerald-400 font-medium">Todos os produtos estão com estoque em dia!</p>
        </div>
      <% end %>
    </div>
  </div>
</div>
