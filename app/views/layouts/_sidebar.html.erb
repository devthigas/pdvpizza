<aside class="w-64 bg-zinc-900 border-r border-zinc-800 flex flex-col justify-between h-screen sticky top-0 text-zinc-300">
  <div class="flex flex-col">
    <!-- Brand Logo -->
    <div class="h-16 flex items-center px-6 border-b border-zinc-800 gap-3">
      <span class="text-2xl">🍕</span>
      <span class="font-bold text-lg text-white tracking-wider">PIZZA<span class="text-orange-500">PDV</span></span>
    </div>

    <!-- Navigation Links -->
    <nav class="flex-1 px-4 py-6 space-y-1 overflow-y-auto max-h-[calc(100vh-10rem)]">
      <%= link_to root_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{current_page?(root_path) ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">📊</span>
        <span>Dashboard</span>
      <% end %>

      <%= link_to new_order_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{current_page?(new_order_path) || controller_name == 'orders' && action_name == 'edit' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">🛍️</span>
        <span class="font-semibold">Novo Pedido</span>
      <% end %>

      <%= link_to orders_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{current_page?(orders_path) && action_name != 'new' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">📋</span>
        <span>Pedidos</span>
      <% end %>

      <%= link_to kitchen_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{current_page?(kitchen_path) ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">🍳</span>
        <span>Cozinha</span>
      <% end %>

      <div class="pt-4 pb-2 px-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider">
        Cardápio
      </div>

      <%= link_to products_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{controller_name == 'products' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">📦</span>
        <span>Produtos</span>
      <% end %>

      <%= link_to flavors_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{controller_name == 'flavors' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">🌶️</span>
        <span>Sabores</span>
      <% end %>

      <%= link_to additionals_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{controller_name == 'additionals' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">➕</span>
        <span>Adicionais</span>
      <% end %>

      <%= link_to categories_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{controller_name == 'categories' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">🏷️</span>
        <span>Categorias</span>
      <% end %>

      <div class="pt-4 pb-2 px-4 text-xs font-semibold text-zinc-500 uppercase tracking-wider">
        Cadastros
      </div>

      <%= link_to customers_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{controller_name == 'customers' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">👥</span>
        <span>Clientes</span>
      <% end %>

      <%= link_to dining_tables_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{controller_name == 'dining_tables' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">🪑</span>
        <span>Mesas</span>
      <% end %>

      <%= link_to delivery_persons_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{controller_name == 'delivery_persons' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">🏍️</span>
        <span>Entregadores</span>
      <% end %>

      <%= link_to cash_registers_path, class: "flex items-center px-4 py-3 rounded-xl transition-all duration-200 group #{controller_name == 'cash_registers' ? 'bg-orange-500 text-white font-medium shadow-lg shadow-orange-500/20' : 'hover:bg-zinc-800 hover:text-white'}" do %>
        <span class="mr-3 text-lg">💰</span>
        <span>Caixa</span>
      <% end %>
    </nav>
  </div>

  <!-- User Section / Logout -->
  <div class="p-4 border-t border-zinc-800 bg-zinc-950/40">
    <div class="flex items-center justify-between">
      <div class="flex items-center space-x-3 overflow-hidden">
        <div class="w-10 h-10 rounded-full bg-orange-600/20 border border-orange-500/30 flex items-center justify-center text-orange-500 font-bold shrink-0">
          <%= Current.session.user.name[0].upcase %>
        </div>
        <div class="overflow-hidden">
          <div class="text-sm font-semibold text-white truncate"><%= Current.session.user.name %></div>
          <div class="text-xs text-zinc-500 truncate"><%= Current.session.user.role.titleize %></div>
        </div>
      </div>
      <%= button_to session_path, method: :delete, class: "p-2 rounded-lg hover:bg-red-500/10 text-zinc-400 hover:text-red-400 transition-colors" do %>
        ❌
      <% end %>
    </div>
  </div>
</aside>
