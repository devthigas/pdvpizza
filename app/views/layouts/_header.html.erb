<header class="h-16 border-b border-zinc-800 bg-zinc-900/50 backdrop-blur-md flex items-center justify-between px-8 sticky top-0 z-30">
  <!-- Title / Breadcrumb -->
  <div class="flex items-center space-x-2">
    <h1 class="text-xl font-bold text-white"><%= content_for(:title) || "Página Inicial" %></h1>
  </div>

  <!-- Actions & Caixa status -->
  <div class="flex items-center space-x-6">
    <!-- Caixa Status -->
    <% active_register = CashRegister.find_by(user: Current.session.user, status: :open) %>
    <% if active_register %>
      <div class="flex items-center bg-emerald-500/10 border border-emerald-500/20 px-3 py-1.5 rounded-full text-xs font-semibold text-emerald-400">
        <span class="w-2 h-2 rounded-full bg-emerald-400 mr-2 animate-pulse"></span>
        Caixa Aberto (Inicial: R$ <%= '%.2f' % active_register.opening_balance %>)
      </div>
    <% else %>
      <div class="flex items-center bg-amber-500/10 border border-amber-500/20 px-3 py-1.5 rounded-full text-xs font-semibold text-amber-400">
        <span class="w-2 h-2 rounded-full bg-amber-400 mr-2"></span>
        Caixa Fechado (Operação Bloqueada)
      </div>
    <% end %>

    <!-- Date Time -->
    <div class="text-sm font-medium text-zinc-400">
      📅 <%= Time.current.strftime("%d/%m/%Y") %>
    </div>
  </div>
</header>

<!-- Flash Messages -->
<% if flash.any? %>
  <div class="fixed top-20 right-6 z-50 space-y-2 max-w-sm">
    <% flash.each do |type, message| %>
      <div class="p-4 rounded-xl border flex items-center shadow-lg transition-all duration-300 transform translate-x-0 <%= type.to_s == 'notice' ? 'bg-emerald-950 border-emerald-800 text-emerald-300' : 'bg-red-950 border-red-800 text-red-300' %>">
        <span class="mr-3 text-lg"><%= type.to_s == 'notice' ? '✅' : '⚠️' %></span>
        <div class="text-sm font-medium"><%= message %></div>
      </div>
    <% end %>
  </div>
<% end %>
