<!DOCTYPE html>
<html class="h-full bg-zinc-950">
  <head>
    <title><%= content_for(:title) || "PizzaPDV - Sistema de Ponto de Venda" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="PizzaPDV">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      body {
        font-family: 'Outfit', sans-serif;
      }
      /* Custom scrollbar for dark UI */
      ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
      }
      ::-webkit-scrollbar-track {
        background: #09090b;
      }
      ::-webkit-scrollbar-thumb {
        background: #27272a;
        border-radius: 4px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #3f3f46;
      }
    </style>
  </head>

  <body class="h-full text-zinc-100 antialiased">
    <% if authenticated? %>
      <div class="flex min-h-screen">
        <!-- Sidebar -->
        <%= render "layouts/sidebar" %>

        <!-- Content Area -->
        <div class="flex-1 flex flex-col bg-zinc-950">
          <!-- Header -->
          <%= render "layouts/header" %>

          <!-- Main View -->
          <main class="flex-1 p-8 overflow-y-auto">
            <%= yield %>
          </main>
        </div>
      </div>
    <% else %>
      <!-- Unauthenticated View (Login, Password Reset) -->
      <main class="min-h-screen flex items-center justify-center bg-zinc-950 px-4">
        <%= yield %>
      </main>
    <% end %>
  </body>
</html>
