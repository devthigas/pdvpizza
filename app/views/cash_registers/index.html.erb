<% content_for :title, "🏪 Controle de Caixa (Fluxo)" %>

<div class="space-y-8">
  <!-- Caixa Ativo / Abertura de Caixa -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg">
    <% if @current_cash_register %>
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <div class="flex items-center space-x-3">
            <span class="w-2.5 h-2.5 rounded-full bg-emerald-400 animate-pulse"></span>
            <h3 class="text-lg font-bold text-white">Caixa em Operação (Aberto)</h3>
          </div>
          <p class="text-xs text-zinc-500 mt-1">Aberto em <%= @current_cash_register.opened_at.strftime("%d/%m/%Y às %H:%M") %> por <%= @current_cash_register.user.name %></p>
          
          <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mt-6">
            <div>
              <span class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider block">Saldo de Abertura</span>
              <span class="text-base font-bold text-white">R$ <%= '%.2f' % @current_cash_register.opening_balance %></span>
            </div>
            <div>
              <span class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider block">Vendas Concluídas</span>
              <span class="text-base font-bold text-emerald-400">R$ <%= '%.2f' % @current_cash_register.total_sales %></span>
            </div>
            <div>
              <span class="text-[10px] font-semibold text-zinc-500 uppercase tracking-wider block">Total Acumulado</span>
              <span class="text-base font-bold text-orange-400">R$ <%= '%.2f' % (@current_cash_register.opening_balance + @current_cash_register.total_sales) %></span>
            </div>
          </div>
        </div>

        <div class="shrink-0 w-full md:w-auto">
          <%= link_to "Visualizar / Fechar Caixa", cash_register_path(@current_cash_register), class: "w-full md:w-auto block text-center px-6 py-3.5 rounded-2xl bg-orange-500 hover:bg-orange-600 text-white font-extrabold text-xs tracking-wide transition-all shadow-lg shadow-orange-500/20" %>
        </div>
      </div>
    <% else %>
      <div class="text-center py-8">
        <div class="w-12 h-12 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-2xl mx-auto mb-4 text-amber-400">
          ⚠️
        </div>
        <h3 class="text-base font-bold text-white">Você não possui caixa aberto</h3>
        <p class="text-xs text-zinc-500 mt-1 mb-6">É necessário abrir o caixa antes de fazer vendas ou registrar pagamentos.</p>
        <%= link_to "Abrir Caixa Agora", new_cash_register_path, class: "px-6 py-3.5 rounded-2xl bg-orange-500 hover:bg-orange-600 text-white font-extrabold text-xs tracking-wide transition-all shadow-lg shadow-orange-500/20 inline-block" %>
      </div>
    <% end %>
  </div>

  <!-- Histórico de Caixas Anteriores -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg">
    <h3 class="text-lg font-bold text-white mb-6">Histórico de Caixas</h3>

    <% if @cash_registers.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm text-zinc-300">
          <thead>
            <tr class="border-b border-zinc-800 text-zinc-500 font-semibold">
              <th class="py-4 px-3">Operador</th>
              <th class="py-4 px-3">Abertura</th>
              <th class="py-4 px-3">Fechamento</th>
              <th class="py-4 px-3 text-right">Saldo Inicial</th>
              <th class="py-4 px-3 text-right">Vendas</th>
              <th class="py-4 px-3 text-right">Saldo Final</th>
              <th class="py-4 px-3 text-right">Diferença</th>
              <th class="py-4 px-3 text-center">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800">
            <% @cash_registers.each do |register| %>
              <tr class="hover:bg-zinc-950/40 transition-colors">
                <td class="py-4 px-3 font-bold text-white">
                  <%= register.user.name %>
                </td>
                <td class="py-4 px-3 text-xs">
                  <%= register.opened_at.strftime("%d/%m/%Y %H:%M") %>
                </td>
                <td class="py-4 px-3 text-xs">
                  <%= register.closed_at&.strftime("%d/%m/%Y %H:%M") || "-" %>
                </td>
                <td class="py-4 px-3 text-right">
                  R$ <%= '%.2f' % register.opening_balance %>
                </td>
                <td class="py-4 px-3 text-right text-emerald-400">
                  R$ <%= '%.2f' % register.total_sales %>
                </td>
                <td class="py-4 px-3 text-right font-semibold">
                  <%= register.closing_balance ? "R$ #{'%.2f' % register.closing_balance}" : "-" %>
                </td>
                <td class="py-4 px-3 text-right font-bold <%= register.balance_difference.to_f < 0 ? 'text-red-400' : (register.balance_difference.to_f > 0 ? 'text-emerald-400' : 'text-zinc-500') %>">
                  <%= register.balance_difference ? "R$ #{'%.2f' % register.balance_difference}" : "-" %>
                </td>
                <td class="py-4 px-3 text-center">
                  <span class="px-2.5 py-1 rounded-xl text-xs font-bold <%= register.open? ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-zinc-800 text-zinc-500' %>">
                    <%= register.status.upcase %>
                  </span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-sm text-zinc-500 text-center py-12">Nenhum registro de caixa encontrado.</p>
    <% end %>
  </div>
</div>
