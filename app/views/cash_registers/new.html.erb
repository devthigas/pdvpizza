<% content_for :title, "🏪 Abertura de Caixa" %>

<div class="max-w-md mx-auto bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-lg">
  <div class="text-center mb-8">
    <div class="w-16 h-16 rounded-2xl bg-orange-600/10 border border-orange-500/20 flex items-center justify-center text-3xl mx-auto mb-4">
      🏪
    </div>
    <h2 class="text-xl font-bold text-white">Abrir Novo Caixa</h2>
    <p class="text-xs text-zinc-500 mt-1">Informe o saldo inicial em dinheiro para a gaveta</p>
  </div>

  <%= form_with model: @cash_register, class: "space-y-6" do |form| %>
    <div>
      <%= form.label :opening_balance, "Fundo de Troco (Saldo Inicial)", class: "block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2" %>
      <div class="relative flex items-center">
        <span class="absolute left-4 text-sm text-zinc-400 font-bold">R$</span>
        <%= form.number_field :opening_balance, step: 0.01, placeholder: "100.00", required: true, class: "block w-full rounded-2xl bg-zinc-950 border border-zinc-800 focus:border-orange-500 focus:ring-1 focus:ring-orange-500 text-zinc-100 placeholder-zinc-700 pl-10 pr-4 py-3.5 focus:outline-none" %>
      </div>
    </div>

    <div>
      <%= form.label :observations, "Observações", class: "block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2" %>
      <%= form.text_area :observations, placeholder: "Opcional: Detalhes sobre troco, operador, turno...", rows: 3, class: "block w-full rounded-2xl bg-zinc-950 border border-zinc-800 focus:border-orange-500 focus:ring-1 focus:ring-orange-500 text-zinc-100 placeholder-zinc-700 px-4 py-3.5 focus:outline-none" %>
    </div>

    <div class="grid grid-cols-2 gap-4 pt-2">
      <%= link_to cash_registers_path, class: "w-full text-center rounded-2xl py-4 bg-zinc-950 border border-zinc-800 hover:bg-zinc-800 text-zinc-400 font-bold text-xs transition-colors" do %>
        Cancelar
      <% end %>
      <%= form.submit "Confirmar Abertura", class: "w-full rounded-2xl py-4 bg-orange-500 hover:bg-orange-600 text-white font-extrabold text-xs tracking-wide transition-all shadow-lg shadow-orange-500/20 cursor-pointer" %>
    </div>
  <% end %>
</div>
