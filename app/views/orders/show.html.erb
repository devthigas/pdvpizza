<% content_for :title, "🧾 Recibo de Venda - #{@order.number}" %>

<div class="max-w-2xl mx-auto bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-lg space-y-6">
  <!-- Brand / Header -->
  <div class="text-center border-b border-zinc-800 pb-6">
    <span class="text-4xl">🍕</span>
    <h2 class="text-2xl font-bold text-white mt-2">PIZZARIA DEV</h2>
    <p class="text-xs text-zinc-500 mt-1">Rua das Pizzas, 777 - Fone: (11) 99999-8888</p>
    <p class="text-[10px] text-zinc-600 mt-0.5">CNPJ: 00.000.000/0001-00</p>
  </div>

  <!-- Detalhes do Pedido -->
  <div class="grid grid-cols-2 gap-4 text-xs text-zinc-400">
    <div>
      <span class="block font-semibold text-zinc-500 uppercase tracking-wider mb-1">Pedido</span>
      <span class="text-sm font-bold text-white"><%= @order.number %></span>
    </div>
    <div>
      <span class="block font-semibold text-zinc-500 uppercase tracking-wider mb-1">Data / Hora</span>
      <span class="text-sm font-bold text-white"><%= @order.created_at.strftime("%d/%m/%Y às %H:%M") %></span>
    </div>
    <div>
      <span class="block font-semibold text-zinc-500 uppercase tracking-wider mb-1">Tipo de Venda</span>
      <span class="text-sm font-bold text-white">
        <%= @order.order_type.titleize %>
        <%= " - Mesa #{@order.dining_table.number}" if @order.mesa? %>
      </span>
    </div>
    <div>
      <span class="block font-semibold text-zinc-500 uppercase tracking-wider mb-1">Atendido por</span>
      <span class="text-sm font-bold text-white"><%= @order.user.name %></span>
    </div>
  </div>

  <!-- Informações do Cliente se houver -->
  <% if @order.customer.present? || @order.delivery? %>
    <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-4 text-xs text-zinc-400 space-y-2">
      <div class="text-white font-bold mb-1">Cliente / Entrega</div>
      <% if @order.customer.present? %>
        <div><span class="text-zinc-500">Nome:</span> <span class="text-zinc-200 font-medium"><%= @order.customer.name %></span></div>
        <div><span class="text-zinc-500">Telefone:</span> <span class="text-zinc-200 font-medium"><%= @order.customer.phone %></span></div>
      <% end %>
      <% if @order.delivery? %>
        <div><span class="text-zinc-500">Endereço:</span> <span class="text-zinc-200 font-medium"><%= @order.delivery_address %></span></div>
      <% end %>
    </div>
  <% end %>

  <!-- Itens Consumidos -->
  <div>
    <h3 class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-3">Itens do Pedido</h3>
    <div class="divide-y divide-zinc-800 border-t border-b border-zinc-800 py-2">
      <% @order.order_items.each do |item| %>
        <div class="py-3 flex justify-between items-start text-sm">
          <div class="pr-4">
            <span class="font-extrabold text-orange-500 mr-2"><%= item.quantity.to_i %>x</span>
            <span class="font-bold text-white"><%= item.description %></span>
            
            <% if item.additionals.any? %>
              <div class="text-xs text-zinc-500 mt-1 pl-4">
                + Adicionais: <%= item.additionals.pluck(:name).join(", ") %>
              </div>
            <% end %>

            <% if item.observation.present? %>
              <div class="text-xs text-amber-500 font-semibold mt-1">Obs: <%= item.observation %></div>
            <% end %>
          </div>
          <span class="font-bold text-white shrink-0">R$ <%= '%.2f' % item.total %></span>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Fechamento Financeiro -->
  <div class="space-y-2 text-xs text-zinc-400">
    <div class="flex justify-between">
      <span>Subtotal:</span>
      <span>R$ <%= '%.2f' % @order.subtotal %></span>
    </div>
    <% if @order.delivery? %>
      <div class="flex justify-between">
        <span>Taxa de Entrega:</span>
        <span>R$ <%= '%.2f' % @order.delivery_fee %></span>
      </div>
    <% end %>
    <div class="flex justify-between">
      <span>Desconto:</span>
      <span class="text-red-400">- R$ <%= '%.2f' % @order.discount %></span>
    </div>
    <div class="flex justify-between text-base font-extrabold text-white pt-2 border-t border-dashed border-zinc-800">
      <span>Total:</span>
      <span class="text-orange-400">R$ <%= '%.2f' % @order.total %></span>
    </div>
  </div>

  <!-- Formas de Pagamento Registradas -->
  <div class="bg-zinc-950 border border-zinc-800 rounded-2xl p-4 space-y-2 text-xs">
    <div class="text-white font-bold mb-2">Forma(s) de Pagamento</div>
    <% @order.payments.each do |pay| %>
      <div class="flex justify-between text-zinc-400">
        <span><%= pay.payment_method.titleize %>:</span>
        <span class="font-bold text-zinc-200">R$ <%= '%.2f' % pay.amount %></span>
      </div>
    <% end %>
    <% if @order.total_paid > @order.total %>
      <div class="flex justify-between text-emerald-400 font-semibold pt-2 border-t border-zinc-900">
        <span>Troco Devolvido:</span>
        <span class="font-extrabold">R$ <%= '%.2f' % (@order.total_paid - @order.total) %></span>
      </div>
    <% end %>
  </div>

  <!-- Status Fiscal Placeholder -->
  <div class="text-center py-2 text-[10px] text-zinc-500 border-t border-zinc-800">
    📄 Cupom Fiscal Não Emitido (Ambiente de Homologação)
  </div>

  <!-- Impressão e Voltar -->
  <div class="grid grid-cols-2 gap-4 shrink-0 pt-4">
    <%= link_to orders_path, class: "w-full text-center rounded-2xl py-3.5 bg-zinc-950 border border-zinc-800 hover:bg-zinc-800 text-zinc-300 font-bold text-xs transition-colors" do %>
      ⬅️ Voltar aos Pedidos
    <% end %>
    <button onclick="window.print();" class="w-full rounded-2xl py-3.5 bg-orange-500 hover:bg-orange-600 text-white font-extrabold text-xs transition-all shadow-md shadow-orange-500/10 cursor-pointer">
      🖨️ Imprimir Recibo
    </button>
  </div>
</div>
