<% content_for :title, "👥 Perfil de #{@customer.name}" %>

<div class="space-y-6">
  <!-- Cabeçalho e Informações Gerais -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-8 shadow-lg">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div class="flex items-center space-x-5">
        <div class="w-16 h-16 rounded-3xl bg-orange-600/10 border border-orange-500/20 flex items-center justify-center text-3xl font-bold text-orange-500">
          <%= @customer.name[0].upcase %>
        </div>
        <div>
          <h2 class="text-2xl font-bold text-white"><%= @customer.name %></h2>
          <p class="text-xs text-zinc-500 mt-1">Cliente cadastrado em <%= l(@customer.created_at, format: :short) %></p>
        </div>
      </div>
      
      <div class="flex items-center space-x-3">
        <%= link_to "Editar Cadastro", edit_customer_path(@customer), class: "px-5 py-3 rounded-2xl bg-zinc-850 hover:bg-zinc-800 border border-zinc-800 text-zinc-300 font-bold text-sm transition-all" %>
        <%= button_to "Excluir Cliente", customer_path(@customer), method: :delete, data: { confirm: "Tem certeza que deseja excluir este cliente?", turbo_confirm: "Tem certeza que deseja excluir este cliente?" }, class: "px-5 py-3 rounded-2xl bg-red-950 hover:bg-red-900 text-red-400 hover:text-red-300 font-bold text-sm transition-all cursor-pointer" %>
        <%= link_to "Voltar", customers_path, class: "px-5 py-3 rounded-2xl bg-zinc-950 border border-zinc-800 hover:bg-zinc-800 text-zinc-500 font-bold text-sm transition-all" %>
      </div>
    </div>

    <!-- Grid de Informações -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mt-8 pt-8 border-t border-zinc-800">
      <div>
        <span class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1">Telefone</span>
        <span class="text-zinc-200 font-medium"><%= @customer.phone %></span>
      </div>
      <div>
        <span class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1">CPF / CNPJ</span>
        <span class="text-zinc-200 font-medium"><%= @customer.cpf_cnpj.present? ? @customer.cpf_cnpj : "Não informado" %></span>
      </div>
      <div class="md:col-span-2">
        <span class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-1">Endereço Completo</span>
        <span class="text-zinc-200 font-medium"><%= @customer.full_address.present? ? @customer.full_address : "Sem endereço cadastrado" %></span>
      </div>
    </div>

    <% if @customer.notes.present? %>
      <div class="mt-6 p-4 rounded-2xl bg-zinc-950/50 border border-zinc-800/60">
        <span class="block text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Observações Internas</span>
        <p class="text-sm text-zinc-400 italic">"<%= @customer.notes %>"</p>
      </div>
    <% end %>
  </div>

  <!-- Métricas Rápidas -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-md">
      <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Pedidos Realizados</div>
      <div class="text-3xl font-extrabold text-white"><%= @orders.count %></div>
    </div>
    
    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-md">
      <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Total Gasto (Concluídos)</div>
      <div class="text-3xl font-extrabold text-emerald-400">
        R$ <%= number_with_precision(@orders.where(status: :completed).sum(:total), precision: 2) %>
      </div>
    </div>

    <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-md">
      <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Ticket Médio</div>
      <div class="text-3xl font-extrabold text-orange-400">
        <% completed_orders = @orders.where(status: :completed) %>
        <% if completed_orders.any? %>
          R$ <%= number_with_precision(completed_orders.sum(:total) / completed_orders.count, precision: 2) %>
        <% else %>
          R$ 0,00
        <% end %>
      </div>
    </div>
  </div>

  <!-- Histórico de Pedidos -->
  <div class="bg-zinc-900 border border-zinc-800 rounded-3xl p-6 shadow-lg">
    <h3 class="text-lg font-bold text-white mb-6">Histórico de Pedidos</h3>
    
    <% if @orders.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse text-sm text-zinc-300">
          <thead>
            <tr class="border-b border-zinc-800 text-zinc-500 font-semibold">
              <th class="py-4 px-3">Pedido</th>
              <th class="py-4 px-3">Tipo</th>
              <th class="py-4 px-3">Data / Hora</th>
              <th class="py-4 px-3 text-center">Status</th>
              <th class="py-4 px-3 text-right">Total</th>
              <th class="py-4 px-3 text-center">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800">
            <% @orders.each do |order| %>
              <tr class="hover:bg-zinc-950/40 transition-colors">
                <td class="py-4 px-3 font-bold text-white">
                  <%= order.number %>
                </td>
                <td class="py-4 px-3">
                  <% case order.order_type %>
                  <% when 'balcao' %>
                    <span class="px-2.5 py-1 rounded-xl text-xs font-bold bg-zinc-800 text-zinc-300">Balcão</span>
                  <% when 'mesa' %>
                    <span class="px-2.5 py-1 rounded-xl text-xs font-bold bg-blue-500/10 text-blue-400">Mesa <%= order.dining_table&.number %></span>
                  <% when 'delivery' %>
                    <span class="px-2.5 py-1 rounded-xl text-xs font-bold bg-purple-500/10 text-purple-400">Delivery</span>
                  <% end %>
                </td>
                <td class="py-4 px-3 text-zinc-400">
                  <%= l(order.created_at, format: :long) %>
                </td>
                <td class="py-4 px-3 text-center">
                  <% case order.status %>
                  <% when 'pending' %>
                    <span class="px-2.5 py-1 rounded-xl text-xs font-bold bg-yellow-500/10 text-yellow-400">Pendente</span>
                  <% when 'in_kitchen' %>
                    <span class="px-2.5 py-1 rounded-xl text-xs font-bold bg-orange-500/10 text-orange-400">Na Cozinha</span>
                  <% when 'ready' %>
                    <span class="px-2.5 py-1 rounded-xl text-xs font-bold bg-indigo-500/10 text-indigo-400">Pronto</span>
                  <% when 'delivering' %>
                    <span class="px-2.5 py-1 rounded-xl text-xs font-bold bg-blue-500/10 text-blue-400">Em Rota</span>
                  <% when 'completed' %>
                    <span class="px-2.5 py-1 rounded-xl text-xs font-bold bg-emerald-500/10 text-emerald-400">Finalizado</span>
                  <% when 'cancelled' %>
                    <span class="px-2.5 py-1 rounded-xl text-xs font-bold bg-red-500/10 text-red-400">Cancelado</span>
                  <% end %>
                </td>
                <td class="py-4 px-3 text-right font-extrabold text-white">
                  R$ <%= number_with_precision(order.total, precision: 2) %>
                </td>
                <td class="py-4 px-3 text-center">
                  <%= link_to "Ver Pedido", order_path(order), class: "px-3 py-1.5 rounded-xl bg-zinc-800 hover:bg-zinc-700 text-zinc-300 font-bold text-xs" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-sm text-zinc-500 text-center py-12">Nenhum pedido registrado para este cliente ainda.</p>
    <% end %>
  </div>
</div>
